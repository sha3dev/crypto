{
  "name": "@sha3/crypto",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "fix": "npm run lint:fix && npm run format:write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:live": "LIVE_FEED_TESTS=1 node --import tsx --test test/integration/*.test.ts",
    "publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@sha3/code-standards": "^0.1.0",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "eslint": "^9.20.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.46.3"
  },
  "codeStandards": {
    "template": "node-lib",
    "profilePath": null,
    "withAiAdapters": true,
    "lastRefreshWith": "0.1.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sha3dev/crypto"
  },
  "homepage": "https://github.com/sha3dev/crypto#readme",
  "bugs": {
    "url": "https://github.com/sha3dev/crypto/issues"
  }
}
